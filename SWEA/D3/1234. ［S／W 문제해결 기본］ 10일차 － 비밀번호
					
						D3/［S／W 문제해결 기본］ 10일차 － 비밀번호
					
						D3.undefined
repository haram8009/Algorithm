T = 10
for test_case in range(1, T + 1):
    result = 0
    N, s = input().split()
    N = int(N)

    stack = []
    
    stack.append(s[0])
    for i in range(1, N):
        if stack and stack[-1] == s[i]:
            stack.pop()
        else:
            stack.append(s[i])    
    
    result = "".join(stack)
    print("#{} {}".format(test_case, result))